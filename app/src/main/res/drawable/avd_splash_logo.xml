<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/ic_splash_logo">

    <!-- Left Book Outline -->
    <target android:name="path_outline_left">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="600"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Right Book Outline -->
    <target android:name="path_outline_right">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="600"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Center Spine -->
    <target android:name="path_spine">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="600"
                android:startDelay="200"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Left Page Line 0 -->
    <target android:name="line_left_0">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="300"
                android:startDelay="180"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Right Page Line 0 -->
    <target android:name="line_right_0">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="300"
                android:startDelay="240"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Left Page Line 1 -->
    <target android:name="line_left_1">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="300"
                android:startDelay="300"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Right Page Line 1 -->
    <target android:name="line_right_1">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="300"
                android:startDelay="360"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Left Page Line 2 -->
    <target android:name="line_left_2">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="300"
                android:startDelay="420"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Right Page Line 2 -->
    <target android:name="line_right_2">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:duration="300"
                android:startDelay="480"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:anim/accelerate_decelerate_interpolator" />
        </aapt:attr>
    </target>

    <!-- Group Ribbon (Dropdown) -->
    <target android:name="group_ribbon">
        <aapt:attr name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="translateY"
                    android:duration="300"
                    android:startDelay="900"
                    android:valueFrom="-20"
                    android:valueTo="0"
                    android:valueType="floatType"
                    android:interpolator="@android:anim/decelerate_interpolator" />
                <!-- Add Fade In -->
                <objectAnimator
                    android:propertyName="alpha"
                    android:duration="300"
                    android:startDelay="900"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:valueType="floatType" />
            </set>
        </aapt:attr>
    </target>

</animated-vector>
