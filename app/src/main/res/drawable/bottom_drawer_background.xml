<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main glass background with frosted effect -->
    <item>
        <shape android:shape="rectangle">
            <!-- Semi-transparent surface color using theme attribute -->
            <solid android:color="?attr/floatingNavBackground" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- Subtle inner highlight for depth -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="?attr/floatingNavStroke" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- Border stroke -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF" />
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp" />
        </shape>
    </item>
</layer-list>
