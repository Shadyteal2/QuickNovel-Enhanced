<?xml version="1.0" encoding="utf-8"?>
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="20dp"
    android:insetRight="20dp"
    android:insetTop="20dp"
    android:insetBottom="20dp">
    <layer-list>
        <!-- Contrast Overlay to enhance backdrop readability -->
        <item>
            <shape>
                <solid android:color="#0D000000" />
                <corners android:radius="24dp" />
            </shape>
        </item>

        <!-- Background Layer (Glass Translucency) -->
        <item>
            <shape>
                <solid android:color="?attr/floatingNavBackground" />
                <corners android:radius="24dp" />
            </shape>
        </item>

        <!-- Glass Shine/Gradient Overlay -->
        <item>
            <shape>
                <gradient
                    android:angle="135"
                    android:startColor="#1AFFFFFF"
                    android:endColor="#00FFFFFF"
                    android:type="linear" />
                <corners android:radius="24dp" />
            </shape>
        </item>

        <!-- Subtle Border Edge Highlight (The "Glass" edge) -->
        <item>
            <shape>
                <stroke android:width="1.5dp" android:color="?attr/floatingNavStroke" />
                <corners android:radius="24dp" />
            </shape>
        </item>
    </layer-list>
</inset>
