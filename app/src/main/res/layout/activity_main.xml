<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:background="@android:color/transparent"
        android:layout_height="match_parent"
        android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
        android:paddingTop="0dp">

    <ImageView
        android:id="@+id/app_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <View
        android:id="@+id/app_background_dim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0"
        android:visibility="gone" />
    
    <View
        android:id="@+id/app_background_light_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:alpha="0"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/main_content_wrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/homeRoot">

        <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_height="match_parent"
                android:layout_width="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false">

            <fragment
                    android:id="@+id/nav_host_fragment"
                    android:name="androidx.navigation.fragment.NavHostFragment"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="invisible"
                    android:alpha="0"
                    app:defaultNavHost="true"
                    app:navGraph="@navigation/mobile_navigation"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/main_viewpager"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="visible"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/home_sync_fab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="124dp"
                    android:contentDescription="Sync Extensions"
                    android:src="@drawable/ic_baseline_autorenew_24"
                    android:visibility="visible"
                    app:backgroundTint="?attr/colorPrimary"
                    app:tint="@android:color/white"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />




            <!-- New Floating Navigation Structure -->
            <!-- ConstraintLayout ensures the 4-tab bar stays centered regardless of the Settings button visibility -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/nav_root_layout"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="24dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- Navigation Cluster (Bar + Settings) Centered as a unit -->
                <!-- Use a Chain to keep them together while clamping to screen edges if needed -->
                
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/nav_bar_container"
                    android:layout_width="wrap_content"
                    android:layout_height="58dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:background="@drawable/glass_nav_background"
                    android:paddingHorizontal="4dp"
                    android:minWidth="330dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/nav_extra_button"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintWidth_max="480dp">

                    <!-- The Pill (Constrained to selected tab in code) -->
                    <View
                        android:id="@+id/nav_indicator_pill"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        android:alpha="0"
                        android:background="@drawable/nav_chip_selected_bg"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/nav_item_download"
                        app:layout_constraintEnd_toEndOf="@+id/nav_item_download" />

                    <!-- Tabs in a weighted Chain -->
                    <include layout="@layout/nav_item_chip" 
                        android:id="@+id/nav_item_download"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/nav_item_search"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <include layout="@layout/nav_item_chip" 
                        android:id="@+id/nav_item_search"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/nav_item_foryou"
                        app:layout_constraintStart_toEndOf="@+id/nav_item_download"
                        app:layout_constraintTop_toTopOf="parent" />

                    <include layout="@layout/nav_item_chip" 
                        android:id="@+id/nav_item_foryou"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/nav_item_history"
                        app:layout_constraintStart_toEndOf="@+id/nav_item_search"
                        app:layout_constraintTop_toTopOf="parent" />

                    <include layout="@layout/nav_item_chip" 
                        android:id="@+id/nav_item_history"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/nav_item_foryou"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <FrameLayout
                    android:id="@+id/nav_extra_button"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:alpha="0"
                    android:visibility="gone"
                    android:background="@drawable/nav_extra_bg"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toTopOf="@id/nav_bar_container"
                    app:layout_constraintBottom_toBottomOf="@id/nav_bar_container"
                    app:layout_constraintStart_toEndOf="@id/nav_bar_container"
                    app:layout_constraintEnd_toEndOf="parent">
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_baseline_settings_24"
                        android:tint="?attr/iconColor" />
                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>
    </FrameLayout>
</FrameLayout>
