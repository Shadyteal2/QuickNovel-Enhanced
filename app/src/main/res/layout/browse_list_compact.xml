<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/browse_background_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="6dp">

        <!-- Glass Background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/glass_card_background" />

        <!-- Glass Border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/glass_card_border" />

        <LinearLayout
            android:id="@+id/browse_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/browse_icon_background"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="?attr/iconGrayBackground"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/browse_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:contentDescription="@string/browse_list_icon"
                    tools:src="@drawable/icon_royalroad" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/browse_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/google_sans"
                android:gravity="center"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Royal Road" />

        </LinearLayout>
    </FrameLayout>
</LinearLayout>