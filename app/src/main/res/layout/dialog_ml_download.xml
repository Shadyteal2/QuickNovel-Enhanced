<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/ml_download_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/download_ml"
        android:textColor="?attr/textColor"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/ml_download_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/download_ml_long"
        android:textColor="?attr/textColor"
        android:alpha="0.75"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/ml_download_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        app:indicatorColor="?attr/colorPrimary"
        app:trackColor="?attr/primaryGrayBackground"
        app:trackCornerRadius="8dp"
        app:trackThickness="8dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/ml_download_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Downloading local model...\nThis may take 10+ minutes depending on your server connection."
        android:textColor="?attr/colorPrimary"
        android:textSize="12sp"
        android:gravity="center"
        android:alpha="0.9" />

</LinearLayout>
