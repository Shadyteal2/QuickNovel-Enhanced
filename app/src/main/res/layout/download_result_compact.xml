<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/backgroundCard"
        android:layoutDirection="ltr"
        android:layout_margin="2dp"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginBottom="2dp"
        app:cardElevation="4dp"

        app:cardCornerRadius="@dimen/roundedImageRadius"
        app:cardBackgroundColor="?attr/boxItemBackground"
        android:clickable="true"
        android:focusable="true">
    <!-- USING CROP RATIO (182/268), centerCrop for fill -->

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <!-- Poster Image: Directly in Root to reduce Overdraw -->
        <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageView"
                android:layout_width="67.5dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedPoster"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/poster_open_source_descript" />

        <!-- Novel Name -->
        <TextView
                android:id="@+id/imageText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="12dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                app:layout_constraintEnd_toStartOf="@+id/download_holder"
                app:layout_constraintStart_toEndOf="@+id/imageView"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Novel Name Overgeared Overgeared Overgeared" />

        <!-- Progress Description -->
        <TextView
                android:id="@+id/download_progress_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@+id/imageText"
                app:layout_constraintStart_toStartOf="@+id/imageText"
                app:layout_constraintTop_toBottomOf="@+id/imageText"
                tools:text="1034/1960 - Paused" />

        <!-- Control Holder (Updates & Delete) -->
        <LinearLayout
                android:id="@+id/download_holder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            <TextView
                    android:id="@+id/imageTextMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="+27" />

            <FrameLayout
                    android:id="@+id/download_update_holder"
                    android:layout_width="48dp"
                    android:layout_height="48dp">

                <androidx.core.widget.ContentLoadingProgressBar
                        android:id="@+id/download_update_loading"
                        style="@style/Widget.AppCompat.ProgressBar"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                <ImageView
                        android:id="@+id/download_update"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?selectableItemBackgroundBorderless"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_baseline_autorenew_24"
                        app:tint="?attr/textColor" />
            </FrameLayout>

            <ImageView
                    android:id="@+id/download_delete_trash"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@string/delete"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_baseline_delete_outline_24"
                    app:tint="?attr/textColor" />
        </LinearLayout>

        <!-- Progress Bar at bottom -->
        <androidx.core.widget.ContentLoadingProgressBar
                android:id="@+id/download_progressbar"
                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_marginStart="10dp"
                android:progressTint="?attr/colorPrimary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageView"
                tools:progress="50" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--<ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="10dp"

            app:tint="?attr/textColor"
            android:layout_gravity="center_vertical|end"
            android:src="@drawable/ic_baseline_more_vert_24"
    >

    </ImageView>-->
</androidx.cardview.widget.CardView>
