<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainpageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">


    <LinearLayout
        android:id="@+id/mainpage_loading_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mainpage_reload_connectionerror"
            style="@style/WhiteButton"

            android:layout_width="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="5dp"

            android:minWidth="200dp"
            android:text="@string/reload_error"
            android:visibility="gone"

            app:icon="@drawable/ic_baseline_autorenew_24"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mainpage_reload_connection_open_in_browser"
            style="@style/BlackButton"
            android:layout_width="wrap_content"
            android:layout_gravity="center"

            android:layout_margin="5dp"

            android:minWidth="200dp"
            android:text="@string/open_in_browser"
            android:visibility="gone"
            app:icon="@drawable/ic_baseline_public_24"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/mainpage_error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="5dp"
            android:gravity="center"
            android:textColor="?attr/textColor"
            tools:text="hello world"
            tools:visibility="visible" />
    </LinearLayout>

    <com.lagradost.quicknovel.widget.AutofitRecyclerView
        android:id="@+id/mainpage_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="160dp"
        android:paddingEnd="8dp"
        android:paddingBottom="130dp"
        android:layout_marginTop="-160dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:spanCount="3" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/mainpage_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:id="@+id/mainpage_header_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            app:layout_scrollFlags="scroll|enterAlways|snap">
            <!-- Search bar and chips content remains here -->

                <LinearLayout
                    android:id="@+id/mainpage_toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:id="@+id/mainpage_search_container"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/vibe_glass_card"
                        android:elevation="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:outlineAmbientShadowColor="?attr/colorPrimary"
                        android:outlineSpotShadowColor="?attr/colorPrimary">

                        <ImageView
                            android:id="@+id/search_back"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:contentDescription="@string/change_providers_descript"
                            android:padding="10dp"
                            android:src="@drawable/ic_baseline_arrow_back_24"
                            app:tint="?attr/iconColor" />

                        <androidx.appcompat.widget.SearchView
                            android:id="@+id/main_search"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:animateLayoutChanges="true"
                            android:iconifiedByDefault="false"
                            app:iconifiedByDefault="false"
                            app:queryBackground="@color/transparent"
                            app:queryHint="@string/search_hint"
                            app:searchHintIcon="@null"
                            app:searchIcon="@null">

                            <androidx.core.widget.ContentLoadingProgressBar
                                android:id="@+id/search_loading_bar"
                                style="@style/Widget.AppCompat.ProgressBar"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="-32dp"
                                android:alpha="0"
                                android:foregroundTint="?attr/colorPrimary"
                                android:progressTint="?attr/colorPrimary" />
                        </androidx.appcompat.widget.SearchView>

                        <ImageView
                            android:id="@+id/search_browse"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:contentDescription="@string/open_in_browser"
                            android:padding="10dp"
                            android:src="@drawable/ic_baseline_public_24"
                            app:tint="?attr/iconColor" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/mainpage_sortby_holder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="22dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/filter_general_spinner"
                        style="@style/DropdownButton"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/vibe_glass_card"
                        android:elevation="6dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        tools:text="General" />

                    <TextView
                        android:id="@+id/filter_order_spinner"
                        style="@style/DropdownButton"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_marginHorizontal="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/vibe_glass_card"
                        android:elevation="6dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        tools:text="Order" />

                    <TextView
                        android:id="@+id/filter_tag_spinner"
                        style="@style/DropdownButton"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/vibe_glass_card"
                        android:elevation="6dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        tools:text="Tag" />
                </LinearLayout>

                <TextView
                    android:id="@+id/mainpage_source_notice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/google_sans"
                    android:gravity="center"
                    android:padding="4dp"
                    android:text="Visual fidelity limited by source"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </LinearLayout>

        </com.google.android.material.appbar.AppBarLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
