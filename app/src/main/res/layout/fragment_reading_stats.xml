<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/stats_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/stats_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
            app:title="Reading Stats"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Profile / Level Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spatial_glass_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/search_background"
                    android:backgroundTint="?attr/colorSurfaceVariant">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_baseline_star_24"
                        android:tint="?attr/colorPrimary" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_level_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Novice"
                        android:textColor="?attr/textColor"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_level_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 1 Reader"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="14sp" />

                    <ProgressBar
                        android:id="@+id/pb_level_progress"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:progress="20"
                        android:progressTint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/tv_level_progress_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1h read / 5h to next"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Compact Metrics Pills Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_pill_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/search_background"
                    android:backgroundTint="#2FFF5252"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="🔥 1"
                    android:textColor="#FF5252"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_pill_chapters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/search_background"
                    android:backgroundTint="#2F2196F3"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="📖 2"
                    android:textColor="#2196F3"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_pill_hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_background"
                    android:backgroundTint="#2F4CAF50"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="🕒 0h"
                    android:textColor="#4CAF50"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 2. Streak Large Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/spatial_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_streak_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 day streak"
                    android:textColor="?attr/textColor"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Start reading today"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_best_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Best: 1 days"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 3. Goals Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Goals"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Daily Goal -->
                <LinearLayout
                    android:id="@+id/ll_daily_goal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/pb_daily_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        app:indicatorSize="64dp"
                        app:trackThickness="6dp"
                        app:indicatorColor="?attr/colorPrimary"
                        app:trackColor="?attr/colorSurfaceVariant"
                        app:trackCornerRadius="4dp"
                        android:progress="30" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Daily Goal"
                        android:textColor="?attr/textColor"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_daily_goal_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 30 min"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Weekly Goal -->
                <LinearLayout
                    android:id="@+id/ll_weekly_goal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/pb_weekly_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        app:indicatorSize="64dp"
                        app:trackThickness="6dp"
                        app:indicatorColor="?attr/colorPrimary"
                        app:trackColor="?attr/colorSurfaceVariant"
                        app:trackCornerRadius="4dp"
                        android:progress="10" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Weekly Goal"
                        android:textColor="?attr/textColor"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_weekly_goal_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 / 180 min"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 4. Insights Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Insights"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Session"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_avg_session"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="1m"
                        android:textColor="#00BCD4"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reading Pace"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_reading_pace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="2.0"
                        android:textColor="#9C27B0"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Best Day"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_best_day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Wed"
                        android:textColor="#FF9800"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 5. This Week Bar Chart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="This Week"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layout_bar_chart"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/spatial_glass_card"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true">
                <!-- Bar item hooks left to setup by scripts later -->
            </LinearLayout>

            <!-- 6. Reading Time Cards -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Reading Time"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_time_today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textColor="#00E676"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Today"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_time_week"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1m"
                        android:textColor="#29B6F6"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="This Week"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/spatial_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_time_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1m"
                        android:textColor="#AB47BC"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="This Month"
                        android:textColor="?attr/grayTextColor"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
