<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/result_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false">



    <LinearLayout
        android:id="@+id/result_loading_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/result_reload_connectionerror"
            style="@style/WhiteButton"
            android:layout_width="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="5dp"
            android:text="@string/reload_error"
            app:icon="@drawable/ic_baseline_autorenew_24" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/result_reload_connection_open_in_browser"
            style="@style/BlackButton"
            android:layout_width="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="5dp"
            android:text="@string/open_in_browser"
            app:icon="@drawable/ic_baseline_public_24" />

        <TextView
            android:id="@+id/result_error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="?attr/textColor" />
    </LinearLayout>

    <!-- Full page backdrop -->
    <!-- Full page ambient glass backdrop -->
    <FrameLayout
        android:id="@+id/result_backdrop_holder"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/result_poster_blur"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.5"
            android:scaleType="centerCrop" />
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/dynamic_glass_gradient" />
    </FrameLayout>

    <!-- Scrollable container FLAT -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/result_mainscroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent">

        <LinearLayout
            android:id="@+id/result_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Title & Hero Frame inside scroll -->
            <LinearLayout
                android:id="@+id/result_info_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="80dp"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <!-- Asymmetric Novel Layout -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <androidx.cardview.widget.CardView
                        android:layout_width="120dp"
                        android:layout_height="180dp"
                        android:elevation="10dp"
                        app:cardCornerRadius="12dp"
                        android:layout_marginEnd="16dp">

                        <ImageView
                            android:id="@+id/result_poster"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_gravity="top"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/result_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/no_data"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textAllCaps="true" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/result_provider_chip"
                                style="@style/Widget.MaterialComponents.Chip.Action"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textSize="10sp"
                                android:textColor="?attr/white"
                                app:chipCornerRadius="16dp"
                                app:chipBackgroundColor="#22FFFFFF"
                                app:chipStrokeColor="#33FFFFFF"
                                app:chipStrokeWidth="1dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/result_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="3"
                            android:text="@string/no_data"
                            android:textColor="?attr/textColor"
                            android:textSize="24sp"
                            android:fontFamily="@font/google_sans"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>

                        <TextView
                            android:id="@+id/result_author"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/no_data"
                            android:textColor="?attr/grayTextColor"
                            android:textSize="14sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>

                        <TextView
                            android:id="@+id/result_total_chapters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textSize="14sp"
                            android:textColor="?attr/textColor"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/result_source_notice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Visual fidelity limited by NovelFull source"
                            android:textColor="?attr/grayTextColor"
                            android:textSize="10sp"
                            android:visibility="gone" />

                        <!-- Visual Progress Bar -->
                        <LinearLayout
                            android:id="@+id/result_progress_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/result_progress_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/grayTextColor"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/result_progress_bar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="6dp"
                                app:trackColor="#33FFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Continue Reading Bar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/result_continue_reading"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#22FFFFFF"
                app:strokeColor="#11FFFFFF"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/netflix_play"
                        app:tint="?attr/textColor"/>
                    <TextView
                        android:id="@+id/result_continue_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Start Reading"
                        android:textColor="?attr/textColor"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bookmark Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/result_bookmark"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="16dp"
                android:text="Add to Library"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:cornerRadius="24dp"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1.5dp"
                android:textColor="?attr/colorPrimary"
                app:iconTint="?attr/colorPrimary"
                android:backgroundTint="@android:color/transparent"/>

            <!-- Tabs and Pagers -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/result_tabs"
                style="@style/Theme.Widget.Tabs"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@color/transparent"
                android:descendantFocusability="blocksDescendants"
                android:focusable="false"
                android:paddingHorizontal="16dp"
                app:tabIndicatorFullWidth="true"
                app:tabGravity="center"
                app:indicatorColor="@android:color/transparent"
                app:tabIndicator="@drawable/tab_pill_indicator"
                app:tabIndicatorAnimationMode="elastic"
                app:tabIndicatorGravity="center"
                app:tabIndicatorHeight="36dp"
                app:tabMode="fixed"
                app:tabSelectedTextColor="?attr/white"
                app:tabTextColor="#BDBDBD"
                app:tabTextAppearance="@style/TabNoCaps" />

            <!-- Empty view has been REMOVED as spacing was flattened -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/result_viewpager"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="10dp"
                android:background="@android:color/transparent"
                android:minHeight="500dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed App Header -->
    <LinearLayout
        android:id="@+id/result_sticky_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/result_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_sharp_clear_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="?attr/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/result_sticky_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/google_sans"
                android:maxLines="1"
                android:textColor="?attr/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:alpha="0"
                tools:text="Novel Title" />

            <!-- keeping ID for link back -->
            <TextView
                android:id="@+id/result_sticky_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/result_openinbrower"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_baseline_public_24"
            app:tint="?attr/white"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <ImageView
            android:id="@+id/result_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_outline_share_24"
            app:tint="?attr/white"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>



    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/result_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:visibility="visible"
        app:shimmer_auto_start="true"
        app:shimmer_base_alpha="0.3"
        app:shimmer_highlight_alpha="0.9"
        app:shimmer_duration="800"
        tools:visibility="gone">

        <include layout="@layout/loading_skeleton_result" />

    </com.facebook.shimmer.ShimmerFrameLayout>

    <!-- Chapter Selection Toolbar (Glass Design) -->


    <!-- Chapters FAB (Move to end for interactivity) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/result_chapters_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="?attr/colorPrimary">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_baseline_filter_list_24"
                app:tint="@android:color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Chapter Selection Toolbar (Move to end for interactivity) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/result_selection_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/primaryGrayBackground"
        app:cardCornerRadius="24dp"
        app:cardElevation="20dp"
        app:strokeColor="?attr/colorPrimary"
        app:strokeWidth="1.5dp"
        tools:visibility="visible">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <ImageView
                    android:id="@+id/result_selection_close"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    android:src="@drawable/ic_sharp_clear_24"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/textColor" />

                <TextView
                    android:id="@+id/result_selection_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/google_sans"
                    android:paddingStart="8dp"
                    android:textColor="?attr/textColor"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="1 Selected" />

                <ImageView
                    android:id="@+id/result_selection_bookmark"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_baseline_bookmark_24"
                    android:contentDescription="Bookmark"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorPrimary" />

                <ImageView
                    android:id="@+id/result_selection_unbookmark"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_baseline_bookmark_border_24"
                    android:contentDescription="Unbookmark"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorPrimary" />

                <ImageView
                    android:id="@+id/result_selection_mark_read"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_baseline_check_24"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/textColor" />

                <ImageView
                    android:id="@+id/result_selection_mark_unread"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_baseline_history_24"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorPrimary" />

                <ImageView
                    android:id="@+id/result_selection_select_all"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@drawable/ic_baseline_select_all_24"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/textColor" />

            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
