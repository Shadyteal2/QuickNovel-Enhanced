<?xml version="1.0" encoding="utf-8"?>

    <FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/backgroundContainer"
        android:layout_width="114dp"
        android:layout_height="180dp"
        android:layout_margin="4dp">

        <!-- Physical Card for Content -->
        <androidx.cardview.widget.CardView
            android:id="@+id/backgroundCard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="?attr/boxItemBackground"
            app:cardCornerRadius="@dimen/roundedImageRadius"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/poster_descript"
                android:scaleType="centerCrop"
                tools:src="@drawable/big_icon_royalroad" />

            <!-- Cinematic Shadow Overlay -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:contentDescription="@string/shadow_descript"
                android:src="@drawable/cinematic_overlay" />

            <TextView
                android:id="@+id/imageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:ellipsize="end"
                android:fontFamily="@font/google_sans"
                android:gravity="center"
                android:maxLines="2"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingBottom="8dp"
                android:textColor="?attr/textColor"
                android:shadowColor="#B4000000"
                android:shadowDx="1.2"
                android:shadowDy="1.2"
                android:shadowRadius="1.5"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Novel Title" />

        </androidx.cardview.widget.CardView>

        <!-- Glass Border Overlay for Premium Feel -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/glass_card_border" />

    </FrameLayout>
