<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/read_settings_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/primaryBlackBackground"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="?android:attr/listPreferredItemPaddingStart"
            android:paddingEnd="?android:attr/listPreferredItemPaddingEnd">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="@string/read_display_settings"
                android:textColor="?attr/textColor"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/hard_reset_stream"
                    style="@style/BlackButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/reload_chapter"
                    app:icon="@drawable/ic_baseline_autorenew_24" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_scroll_vol"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/scroll_with_volume_keys"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    tools:checked="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_lock_tts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lock_tts"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_show_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/show_time"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_show_battery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/show_battery"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_show_bionic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/bionic_reading"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_is_text_selectable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/selectable_text"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_keep_screen_active"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/keep_screen_active"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_settings_author_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/show_authors_notes"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/text_font"
                android:textColor="?attr/textColor"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/scroll_type"
                    android:textSize="15sp"
                    android:textColor="?attr/grayTextColor" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/read_reading_type"
                    style="@style/BlackButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:icon="@drawable/swipe_vertical_24px"
                    tools:text="@string/inf_scroll" />

                <TextView
                    android:id="@+id/read_settings_text_font_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_font"
                    android:textSize="15sp"
                    android:textColor="?attr/grayTextColor" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/read_show_fonts"
                    style="@style/BlackButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="8dp"
                    android:text="@string/reader_font"
                    app:icon="@drawable/ic_baseline_font_download_24" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/tts_voice_title"
                android:textColor="?attr/textColor"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_language"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="0dp"
                        android:text="@string/tts_locale"
                        app:icon="@drawable/ic_baseline_language_24" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_voice"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/tts_voice"
                        app:icon="@drawable/ic_baseline_volume_up_24" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_sleep_timer"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="0dp"
                        android:text="@string/sleep_timer"
                        app:icon="@drawable/nights_stay_24px" />
                </LinearLayout>

                <TextView
                    android:id="@+id/read_settings_tts_speed_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/tts_speed"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/pace_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_tts_speed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/white" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/read_settings_tts_speed"
                        style="@style/SettingsSliderTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="0.1"
                        android:value="1.0"
                        android:valueFrom="0.1"
                        android:valueTo="5"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/acute_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/read_settings_tts_speed"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/white" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_tts_pitch_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/tts_pitch"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/hiking_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_tts_pitch"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/white" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/read_settings_tts_pitch"
                        style="@style/SettingsSliderTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="0.1"
                        android:value="1.0"
                        android:valueFrom="0.1"
                        android:valueTo="3"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/directions_run_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/read_settings_tts_pitch"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/white" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_size_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/text_size"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/smaller_font"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_size"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/read_settings_text_size"
                        style="@style/SettingsSliderTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1"
                        android:value="4"
                        android:valueFrom="0"
                        android:valueTo="10"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/bigger_font"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_size"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_padding_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/text_padding"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/format_padding_decrease_white_24dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_padding"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/read_settings_text_padding"
                        style="@style/SettingsSliderTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1"
                        android:value="4"
                        android:valueFrom="0"
                        android:valueTo="10"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/format_padding_increase_white_24dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_padding"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_padding_text_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/text_padding_top"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/text_top_bottom_margin"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_padding_top"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/read_settings_text_padding_top"
                        style="@style/SettingsSliderTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1"
                        android:value="4"
                        android:valueFrom="0"
                        android:valueTo="10"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/text_top_bottom_margin_expand"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_padding_top"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_vertical_padding_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/paragraph_spacing"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/density_small_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_vertical_padding"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/read_settings_text_vertical_padding"
                        style="@style/SettingsSliderTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="0.5"
                        android:value="7.5"
                        android:valueFrom="0"
                        android:valueTo="30.0"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:src="@drawable/density_medium_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_vertical_padding"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>


            <TextView
                android:id="@+id/read_ml_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/google_translate"
                android:textColor="?attr/textColor"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_ml_from"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="0dp"
                        android:text="@string/tts_locale"
                        app:icon="@drawable/ic_baseline_menu_book_24"
                        tools:text="English" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_ml_to"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text=""
                        app:icon="@drawable/fiber_new_24px"
                        tools:text="English" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_apply_translation"
                        style="@style/WhiteButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="0dp"
                        android:text="@string/sort_apply"
                        app:icon="@drawable/translate_24px" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/read_online_translation_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/online_translate"
                    android:textSize="16sp"
                    android:textColor="?attr/textColor" />
            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/read_color"
                android:textColor="?attr/textColor"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/read_settings_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
