<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/read_settings_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:orientation="vertical">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/drag_handle_background"
        android:alpha="0.3" />


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="?android:attr/listPreferredItemPaddingStart"
            android:paddingEnd="?android:attr/listPreferredItemPaddingEnd">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="@string/read_display_settings"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/hard_reset_stream"
                    style="@style/BlackButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/reload_chapter"
                    app:icon="@drawable/ic_baseline_autorenew_24" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/scroll_with_volume_keys"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_scroll_vol"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/lock_tts"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_lock_tts"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/show_time"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_show_time"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/show_battery"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_show_battery"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bionic_reading"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_show_bionic"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/selectable_text"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_is_text_selectable"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/keep_screen_active"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_keep_screen_active"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/show_authors_notes"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_author_notes"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/read_settings_character_aliases"
                    style="@style/BlackButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="8dp"
                    android:text="@string/character_aliases"
                    app:icon="@drawable/ic_baseline_font_download_24" />
            </LinearLayout>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/text_font"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/scroll_type"
                    android:textSize="15sp"
                    android:textColor="?attr/grayTextColor" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/read_reading_type"
                    style="@style/BlackButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:icon="@drawable/swipe_vertical_24px"
                    tools:text="@string/inf_scroll" />

                <TextView
                    android:id="@+id/read_settings_text_font_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_font"
                    android:textSize="15sp"
                    android:textColor="?attr/grayTextColor" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/read_show_fonts"
                    style="@style/BlackButton"
                    android:layout_width="match_parent"
                    android:layout_marginTop="8dp"
                    android:text="@string/reader_font"
                    app:icon="@drawable/ic_baseline_font_download_24" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/tts_voice_title"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_language"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="0dp"
                        android:text="@string/tts_locale"
                        app:icon="@drawable/ic_baseline_language_24" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_voice"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/tts_voice"
                        app:icon="@drawable/ic_baseline_volume_up_24" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_sleep_timer"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="0dp"
                        android:text="@string/sleep_timer"
                        app:icon="@drawable/nights_stay_24px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Use Google TTS (Neural Online)"
                        android:textSize="16sp"
                        android:textColor="?attr/textColor" />
                    <com.lagradost.quicknovel.ui.custom.ElasticSwitch
                        android:id="@+id/read_settings_use_google"
                        android:layout_width="64dp"
                        android:layout_height="32dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/read_settings_tts_speed_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/tts_speed"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:id="@+id/read_settings_tts_speed_icon_left"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/pace_24px"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_tts_speed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_tts_speed"
                        app:tint="?attr/white" />

                    <com.lagradost.quicknovel.ui.custom.TactileRulerSlider
                        android:id="@+id/read_settings_tts_speed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        app:stepSize="0.1"
                        app:valueFrom="0.1"
                        app:valueTo="5.0"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_tts_speed_icon_right"
                        app:layout_constraintStart_toEndOf="@id/read_settings_tts_speed_icon_left"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/read_settings_tts_speed_icon_right"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/acute_24px"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_tts_speed"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_tts_speed"
                        app:tint="?attr/white" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_tts_pitch_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/tts_pitch"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:id="@+id/read_settings_tts_pitch_icon_left"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/hiking_24px"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_tts_pitch"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_tts_pitch"
                        app:tint="?attr/white" />

                    <com.lagradost.quicknovel.ui.custom.TactileRulerSlider
                        android:id="@+id/read_settings_tts_pitch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        app:stepSize="0.1"
                        app:valueFrom="0.1"
                        app:valueTo="3.0"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_tts_pitch_icon_right"
                        app:layout_constraintStart_toEndOf="@id/read_settings_tts_pitch_icon_left"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/read_settings_tts_pitch_icon_right"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/directions_run_24px"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_tts_pitch"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_tts_pitch"
                        app:tint="?attr/white" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_size_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/text_size"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:id="@+id/read_settings_text_size_icon_left"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/smaller_font"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_size"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_size" />

                    <com.lagradost.quicknovel.ui.custom.TactileRulerSlider
                        android:id="@+id/read_settings_text_size"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        app:stepSize="1.0"
                        app:valueFrom="10.0"
                        app:valueTo="30.0"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_size_icon_right"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_size_icon_left"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/read_settings_text_size_icon_right"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/bigger_font"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_size"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_size" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_padding_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/text_padding"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:id="@+id/read_settings_text_padding_icon_left"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/format_padding_decrease_white_24dp"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_padding"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_padding" />

                    <com.lagradost.quicknovel.ui.custom.TactileRulerSlider
                        android:id="@+id/read_settings_text_padding"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        app:stepSize="1.0"
                        app:valueFrom="0.0"
                        app:valueTo="50.0"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_padding_icon_right"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_padding_icon_left"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/read_settings_text_padding_icon_right"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/format_padding_increase_white_24dp"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_padding"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_padding" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_padding_text_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/text_padding_top"
                    android:textSize="14sp"
                    android:textColor="?attr/grayTextColor" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:id="@+id/read_settings_text_padding_top_icon_left"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/text_top_bottom_margin"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_padding_top"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_padding_top" />

                    <com.lagradost.quicknovel.ui.custom.TactileRulerSlider
                        android:id="@+id/read_settings_text_padding_top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        app:stepSize="1.0"
                        app:valueFrom="0.0"
                        app:valueTo="50.0"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_padding_top_icon_right"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_padding_top_icon_left"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/read_settings_text_padding_top_icon_right"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/text_top_bottom_margin_expand"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_padding_top"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_padding_top" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/read_settings_text_vertical_padding_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/paragraph_spacing"
                    android:textSize="14sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold" />


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:id="@+id/read_settings_text_vertical_padding_icon_left"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/density_small_24px"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_vertical_padding"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_vertical_padding" />

                    <com.lagradost.quicknovel.ui.custom.TactileRulerSlider
                        android:id="@+id/read_settings_text_vertical_padding"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        app:stepSize="0.5"
                        app:valueFrom="0.0"
                        app:valueTo="30.0"
                        app:layout_constraintEnd_toStartOf="@id/read_settings_text_vertical_padding_icon_right"
                        app:layout_constraintStart_toEndOf="@id/read_settings_text_vertical_padding_icon_left"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/read_settings_text_vertical_padding_icon_right"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:src="@drawable/density_medium_24px"
                        app:layout_constraintBottom_toBottomOf="@id/read_settings_text_vertical_padding"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/read_settings_text_vertical_padding" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/read_ml_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/google_ml"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                
                <ImageButton
                    android:id="@+id/read_ml_info_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_google_ml"
                    app:tint="?attr/colorPrimary" />
            </LinearLayout>

            <TextView
                android:id="@+id/google_ml_kit_info_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp"
                android:text="Downloading can take upto 10mins depending on google server" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_ml_from"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="0dp"
                        android:text="@string/tts_locale"
                        app:icon="@drawable/ic_baseline_menu_book_24"
                        tools:text="English" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_ml_to"
                        style="@style/BlackButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text=""
                        app:icon="@drawable/fiber_new_24px"
                        tools:text="English" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/read_apply_translation"
                        style="@style/WhiteButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="0dp"
                        android:text="@string/sort_apply"
                        app:icon="@drawable/translate_24px" />
                </LinearLayout>

                <!-- Removed Auto-translate switch per user request -->
            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/read_color"
                android:textColor="?attr/grayTextColor"
                android:textSize="18sp"
                android:textStyle="bold" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spatial_glass_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:elevation="4dp"
                android:outlineProvider="background">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/read_settings_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
