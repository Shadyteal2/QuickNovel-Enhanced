<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp">

    <LinearLayout
        android:layout_margin="10dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/result_views"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/no_data"
                android:textColor="?attr/textColor"
                android:textSize="17sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/views"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp" />
        </LinearLayout>


        <LinearLayout
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/result_rating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/no_data"
                android:textColor="?attr/textColor"
                android:textSize="17sp"
                tools:text="4.4★" />

            <TextView
                android:id="@+id/result_rating_voted_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/no_data"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/result_chapters_info_holder"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/result_chapters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/no_data"
                android:textColor="?attr/textColor"
                android:textSize="17sp"
                tools:text="1230" />

            <TextView
                android:id="@+id/result_chapters_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/chapters"
                android:textColor="?attr/grayTextColor"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/result_updates_toggle_holder"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical">
            <ImageView
                android:id="@+id/result_updates_toggle"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_gravity="center"
                android:background="@drawable/ripple_masked_rounded"
                android:clickable="true"
                android:focusable="true"
                android:padding="5dp"
                android:src="@drawable/ic_baseline_notifications_active_24"
                app:tint="?attr/textColor" />
        </FrameLayout>
    </LinearLayout>


    <View
        android:alpha="0.5"
        android:layout_margin="5dp"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/textColor"/>

    <TextView
        android:id="@+id/result_synopsis_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:textColor="?attr/textColor"
        android:textSize="14sp"
        tools:text="Synopsis text goes here..." />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/result_tag"
        style="@style/ChipParent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        app:chipSpacingVertical="-7dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_gravity="bottom"
        android:layout_margin="0dp"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/result_notes_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="10dp"
            android:hint="@string/notes"
            app:boxStrokeColor="?attr/colorPrimary"
            app:hintTextColor="?attr/colorPrimary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/result_notes_edittext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:minLines="1"
                android:maxLines="6"
                android:scrollbars="vertical"
                android:textColor="?attr/textColor" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/download_warning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginHorizontal="10dp"
            android:text="@string/long_download_time"
            android:textColor="@color/colorPrimaryRed"
            android:textSize="17sp"
            android:textStyle="normal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/result_download_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                tools:text="@string/no_data" />

            <TextView
                android:id="@+id/result_download_progress_text_eta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:gravity="end"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                tools:text="@string/no_data" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp">

            <androidx.core.widget.ContentLoadingProgressBar
                android:id="@+id/result_download_progress_bar"
                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:indeterminate="false"
                android:progressBackgroundTint="?attr/textColor"
                android:progressTint="?attr/textColor"
                tools:progress="50" />

            <androidx.core.widget.ContentLoadingProgressBar
                android:id="@+id/result_download_progress_bar_not_downloaded"
                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:indeterminate="false"
                android:progressBackgroundTint="@color/transparent"
                android:progressTint="?attr/colorPrimary"
                tools:progress="20" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/result_download_generate_epub"
                style="@style/WhiteButton"
                android:layout_width="50dp"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/read_epub"
                app:icon="@drawable/ic_baseline_menu_book_24"
                app:iconSize="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/result_download_btt"
                style="@style/WhiteButton"
                android:layout_width="50dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/download_text"
                app:iconSize="30dp" />
        </LinearLayout>




        <!-- Progress Layout from ResultFragment code -->
        <LinearLayout
            android:id="@+id/result_progress_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView
                android:id="@+id/result_progress_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/textColor"
                android:textSize="14sp"
                tools:text="80% Read" />
            <ProgressBar
                android:id="@+id/result_progress_bar"
                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
