<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="16dp">

    <!-- Top Toolbar (OpenTune style) -->
    <ImageView
        android:id="@+id/settings_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="12dp"
        android:src="@drawable/ic_baseline_arrow_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/white" />

    <TextView
        android:id="@+id/settings_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/productsans_bold"
        android:letterSpacing="0.02"
        android:text="Settings"
        android:textColor="?attr/white"
        android:textSize="38sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settings_back" />

    <ImageView
        android:id="@+id/settings_search_mock"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@drawable/ic_baseline_search_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/white" />

    <!-- Hero About Card (Brand identity) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/hero_about_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="@dimen/roundedImageRadius"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/settings_title"
        app:strokeColor="?attr/iconGrayBackground"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/spatial_glass_card"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/neoqn_logo_container"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardBackgroundColor="?attr/iconGrayBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_quicknovel" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/neoqn_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/productsans_bold"
                android:text="NeoQN"
                android:textColor="?attr/white"
                android:textSize="22sp"
                app:layout_constraintStart_toEndOf="@id/neoqn_logo_container"
                app:layout_constraintTop_toTopOf="@id/neoqn_logo_container" />

            <TextView
                android:id="@+id/hero_about_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Premium Reader Experience"
                android:textColor="?attr/grayTextColor"
                android:textSize="14sp"
                app:layout_constraintStart_toEndOf="@id/neoqn_logo_container"
                app:layout_constraintTop_toBottomOf="@id/neoqn_name" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Reading Stats Card (Dedicated progress card) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/reading_stats_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="@dimen/roundedImageRadius"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/hero_about_card"
        app:strokeColor="?attr/iconGrayBackground"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/spatial_glass_card"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/stats_icon_bg"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="?attr/iconGrayBackground"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/iconGrayBackground"
                app:strokeWidth="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/stats_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_baseline_history_24"
                    app:tint="?attr/white" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/hero_stats_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/productsans_bold"
                android:text="Reading Status"
                android:textColor="?attr/white"
                android:textSize="17sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/stats_icon_bg"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bento Grid (2x2 Replacement with LinearLayouts for maximum compatibility) -->
    <LinearLayout
        android:id="@+id/bento_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/reading_stats_card">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:orientation="horizontal">

            <!-- Appearance -->
            <FrameLayout
                android:id="@+id/bento_appearance"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:layout_weight="1">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/roundedImageRadius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconGrayBackground"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/spatial_glass_card"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/appearance_icon_bg"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="?attr/iconGrayBackground"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/iconGrayBackground"
                            app:strokeWidth="1dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:src="@drawable/ic_baseline_color_lens_24"
                                app:tint="?attr/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsans_bold"
                            android:text="Appearance"
                            android:textColor="?attr/white"
                            android:textSize="17sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Reader -->
            <FrameLayout
                android:id="@+id/bento_reader"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:layout_weight="1">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/roundedImageRadius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconGrayBackground"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/spatial_glass_card"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/reader_icon_bg"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="?attr/iconGrayBackground"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/iconGrayBackground"
                            app:strokeWidth="1dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:src="@drawable/ic_baseline_menu_book_24"
                                app:tint="?attr/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsans_bold"
                            android:text="Reader"
                            android:textColor="?attr/white"
                            android:textSize="17sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:orientation="horizontal">

            <!-- Storage -->
            <FrameLayout
                android:id="@+id/bento_storage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:layout_weight="1">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/roundedImageRadius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconGrayBackground"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/spatial_glass_card"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/storage_icon_bg"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="?attr/iconGrayBackground"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/iconGrayBackground"
                            app:strokeWidth="1dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:src="@drawable/ic_baseline_cloud_24"
                                app:tint="?attr/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsans_bold"
                            android:text="Storage"
                            android:textColor="?attr/white"
                            android:textSize="17sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Advanced -->
            <FrameLayout
                android:id="@+id/bento_advanced"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:layout_weight="1">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/roundedImageRadius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconGrayBackground"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/spatial_glass_card"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/advanced_icon_bg"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="?attr/iconGrayBackground"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/iconGrayBackground"
                            app:strokeWidth="1dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:src="@drawable/ic_baseline_tune_24"
                                app:tint="?attr/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/productsans_bold"
                            android:text="Advanced"
                            android:textColor="?attr/white"
                            android:textSize="17sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Social Chips Row -->
    <HorizontalScrollView
        android:id="@+id/social_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/bento_container">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:background="@drawable/glass_nav_background"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <LinearLayout
                android:id="@+id/chip_discord"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:alpha="0.85"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_baseline_discord_24"
                    app:tint="?attr/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/productsans_bold"
                    android:text="Discord"
                    android:textColor="?attr/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <LinearLayout
                android:id="@+id/chip_telegram"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:alpha="0.85"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_telegram"
                    app:tint="?attr/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/productsans_bold"
                    android:text="Telegram"
                    android:textColor="?attr/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33FFFFFF" />

            <LinearLayout
                android:id="@+id/chip_github"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:alpha="0.85"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_github_logo"
                    app:tint="?attr/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/productsans_bold"
                    android:text="GitHub"
                    android:textColor="?attr/white"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
